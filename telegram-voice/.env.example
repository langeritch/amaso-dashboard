# Copy to .env and fill in. Both values come from https://my.telegram.org/apps.
# They identify the *developer app*, not the user account — the same pair
# is reused across every session you sign into.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Phone numbers the service uses. The "assistant" number is what logs in;
# the "target" number is the default dial-out destination when /call is
# hit without an explicit user_id.
ASSISTANT_PHONE=+31618243012
TARGET_PHONE=+31648935807

# Where Pyrogram writes its encrypted session. Relative paths are resolved
# against this directory. Keep out of git (.gitignore already covers it).
SESSION_NAME=assistant

# Kokoro TTS sidecar. The dashboard auto-starts this on port 3939;
# leave TTS_PORT unset unless you've reconfigured it there too. Voice,
# speed, and language default to whatever the sidecar was started with
# — match Santi's dashboard config automatically.
TTS_PORT=3939
TTS_VOICE=
TTS_SPEED=

# Whisper model — "base.en" is the fastest thing that's actually usable;
# "small.en" is the sweet spot on a GPU; "tiny.en" if you're on CPU-only
# and care about latency over accuracy.
WHISPER_MODEL=small.en
WHISPER_DEVICE=auto   # auto | cuda | cpu

# HTTP listener. Bind to 127.0.0.1 unless you have a very specific reason
# not to — this service has no auth of its own and trusts the dashboard
# to front it.
SERVICE_HOST=127.0.0.1
SERVICE_PORT=8765

# Shared secret the dashboard sends in the `X-Auth` header. Any random
# string. Prevents other processes on the box from dialing Santi.
SERVICE_TOKEN=

# Dashboard base URL — where the service POSTs /api/telegram/respond,
# /acquire, and /release. Defaults to the Node server on loopback; only
# override if you're running the dashboard on a different port or host.
AMASO_DASHBOARD_URL=http://127.0.0.1:3737

# Anthropic key for the incoming-call conversation loop. Required for
# inbound mode only — outbound (/call, /speak) works without it.
ANTHROPIC_API_KEY=
# Override if you want a different model for voice replies. Haiku 4.5
# is the default; Sonnet/Opus add latency the caller will hear.
TELEGRAM_LLM_MODEL=claude-haiku-4-5-20251001
TELEGRAM_LLM_MAX_TOKENS=180
