# Session signing key — random 32 bytes generated on first boot.
# Anyone with this file can forge auth cookies. Never commit.
data/.session-secret
# Per-user knowledge graph: personal facts the assistant has learned
# about each user across conversations. Never commit — it contains
# names, routines, preferences, etc.
data/user-knowledge-graph/
